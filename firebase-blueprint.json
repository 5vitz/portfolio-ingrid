{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "reels"] },
        "mediaUrl": { "type": "string", "description": "Single URL for video or comma-separated for reels" },
        "thumbnail": { "type": "string" },
        "order": { "type": "number" },
        "reelsData": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "videoUrl": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["title", "type", "order"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client testimonial",
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "photoUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["author", "text", "order"]
    },
    "Service": {
      "title": "Service",
      "description": "Offered service",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["title", "order"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global site configuration",
      "type": "object",
      "properties": {
        "heroVideoUrl": { "type": "string" },
        "logoName": { "type": "string" },
        "logoSubtitle": { "type": "string" },
        "contactEmail": { "type": "string" },
        "linkedinUrl": { "type": "string" },
        "whatsappNumber": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "Admin user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Client testimonials"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Services offered"
    },
    "/settings/global": {
      "schema": "SiteSettings",
      "description": "Global site settings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin users"
    }
  }
}
