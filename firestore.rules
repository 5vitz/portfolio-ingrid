rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields: title (string), category (string), type (string), mediaUrl (string), thumbnail (string), order (number), reelsData (array)
    //
    // Collection: testimonials
    // Fields: author (string), role (string), text (string), photoUrl (string), order (number)
    //
    // Collection: services
    // Fields: title (string), items (list), order (number)
    //
    // Collection: settings
    // Document: global
    // Fields: heroVideoUrl (string), logoName (string), logoSubtitle (string), contactEmail (string), linkedinUrl (string), whatsappNumber (string)
    //
    // Collection: users
    // Fields: email (string), role (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sinkando@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'type', 'order']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type in ['video', 'reels'] &&
             data.order is number;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['author', 'text', 'order']) &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.order is number;
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'order']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.order is number;
    }

    function isValidSettings(data) {
      return data.logoName is string && data.logoName.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable data
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProject(request.resource.data);
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTestimonial(request.resource.data);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidService(request.resource.data);
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
